# Backend Environment Variables Example File
# Rename this file to .env and fill in your actual production values

PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb://127.0.0.1:27017/contact-management

# Security Secrets (Generate random secure strings for these)
JWT_SECRET=your_jwt_secure_secret_here
SESSION_SECRET=your_session_secure_secret_here

# Google OAuth Credentials (Get these directly from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The URL of your deployed frontend (e.g., https://my-app.vercel.app or http://localhost:5173 for local)
FRONTEND_URL=http://localhost:5173
